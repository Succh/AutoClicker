<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- 第一行：名称 + 状态 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_config_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="配置名称"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#212121" />

            <TextView
                android:id="@+id/tv_run_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏸ 就绪"
                android:textSize="12sp"
                android:textColor="@color/ready" />
        </LinearLayout>

        <!-- 描述 -->
        <TextView
            android:id="@+id/tv_config_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="无描述"
            android:textSize="13sp"
            android:textColor="#757575"
            android:layout_marginTop="4dp" />

        <!-- 信息行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp">

            <TextView
                android:id="@+id/tv_action_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 个动作"
                android:textSize="12sp"
                android:textColor="#9E9E9E"
                android:background="#F0F0F0"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp" />

            <TextView
                android:id="@+id/tv_loop_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="循环 1 次"
                android:textSize="12sp"
                android:textColor="#9E9E9E"
                android:background="#F0F0F0"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:layout_marginStart="6dp" />
        </LinearLayout>

        <!-- 操作按钮行 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE"
            android:layout_marginVertical="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <ImageButton
                android:id="@+id/btn_edit"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_menu_edit"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="编辑"
                android:scaleType="centerInside" />

            <ImageButton
                android:id="@+id/btn_export"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_menu_share"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="导出"
                android:layout_marginStart="4dp"
                android:scaleType="centerInside" />

            <ImageButton
                android:id="@+id/btn_delete"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_menu_delete"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="删除"
                android:layout_marginStart="4dp"
                android:scaleType="centerInside" />

            <ImageButton
                android:id="@+id/btn_run_stop"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_media_play"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="运行"
                android:layout_marginStart="8dp"
                android:scaleType="centerInside" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
